# ─── Autonomous Coding Assistant — Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file (it is already in .gitignore).

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Docker Compose default (matches docker-compose.yml):
DATABASE_URL=postgresql://user:password@db:5432/antigravity

# For local manual setup (PostgreSQL running on your machine):
# DATABASE_URL=postgresql://user:password@localhost:5432/antigravity

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters
# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_replace_this_with_openssl_rand_hex_32

# ── AI (Optional) ─────────────────────────────────────────────────────────────
# OpenAI API key for GPT-4o-mini responses and FAISS embeddings.
# The system works WITHOUT this key — analysis agents use smart fallback.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
